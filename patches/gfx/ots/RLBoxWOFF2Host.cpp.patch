+// REYNARD: iOS fallback path for valid WOFF2 webfonts when RLBox conversion
+// fails; decode with native woff2 and continue through the same OTS validation
+// via ProcessTTC/ProcessTTF.
+static bool ProcessWOFF2Unsandboxed(ots::FontFile* aHeader,
+                                    ots::OTSStream* aOutput,
+                                    const uint8_t* aData, size_t aLength,
+                                    uint32_t aIndex,
+                                    ProcessTTCFunc* aProcessTTC,
+                                    ProcessTTFFunc* aProcessTTF) {
+  size_t limit =
+      std::min(size_t(OTS_MAX_DECOMPRESSED_FILE_SIZE), aOutput->size());
+  uint32_t decompressedSize = ComputeWOFF2FinalSize(aData, aLength, limit);
+  if (!decompressedSize) {
+    return false;
+  }
+
+  std::string buffer(decompressedSize, 0);
+  woff2::WOFF2StringOut out(&buffer);
+  out.SetMaxSize(decompressedSize);
+  if (!woff2::ConvertWOFF2ToTTF(aData, aLength, &out)) {
+    return false;
+  }
+
+  const uint8_t* decompressed = reinterpret_cast<const uint8_t*>(buffer.data());
+  if (!decompressed) {
+    return false;
+  }
+
+  if (aData[4] == 't' && aData[5] == 't' && aData[6] == 'c' &&
+      aData[7] == 'f') {
+    return aProcessTTC(aHeader, aOutput, decompressed, out.Size(), aIndex);
+  }
+
+  ots::Font font(aHeader);
+  return aProcessTTF(aHeader, &font, aOutput, decompressed, out.Size(), 0);
+}
