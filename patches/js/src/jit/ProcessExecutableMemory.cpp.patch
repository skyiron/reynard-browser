+static bool ShouldRequestDebuggerPreparePage(uintptr_t aPageStart) {
+  uint64_t pageTag =
+      (static_cast<uint64_t>(aPageStart >> DebugPreparePageShift)) + 1u;
+  size_t slot = static_cast<size_t>((pageTag * 11400714819323198485ull) &
+                                    (DebugPrepareCacheEntries - 1));
+
+  if (sDebuggerPreparedPageTags[slot] == pageTag) {
+    return false;
+  }
