+  sDebuggerPreparedPageTags[slot] = pageTag;
+  return true;
+}
+
+// REYNARD: Decommitted executable pages can later be recommitted with new code;
+// clear page-tag cache entries so the next executable transition re-runs
+// debugger-backed prepare for those pages.
+static void InvalidateDebuggerPrepareCacheRange(void* aAddress, size_t aSize) {
+  if (!aAddress || !aSize || !sExecutableMemoryBase) {
+    return;
+  }
+
+  auto* executable = static_cast<uint8_t*>(aAddress);
+  auto* begin = sExecutableMemoryBase;
+  auto* end = begin + MaxCodeBytesPerProcess;
+  if (executable < begin || executable + aSize > end) {
+    return;
+  }
+
+  uintptr_t rangeStart = reinterpret_cast<uintptr_t>(executable);
+  if (aSize > (std::numeric_limits<uintptr_t>::max() - rangeStart)) {
+    return;
+  }
+
+  uintptr_t firstPageStart = rangeStart & ~(DebugPreparePageSize - 1);
+  uintptr_t lastPageStart =
+      (rangeStart + aSize - 1) & ~(DebugPreparePageSize - 1);
+
+  for (uintptr_t page = firstPageStart; page <= lastPageStart;
+       page += DebugPreparePageSize) {
+    uint64_t pageTag =
+        (static_cast<uint64_t>(page >> DebugPreparePageShift)) + 1u;
+    size_t slot = static_cast<size_t>((pageTag * 11400714819323198485ull) &
+                                      (DebugPrepareCacheEntries - 1));
+    sDebuggerPreparedPageTags[slot] = 0;
+  }
+}
+
+// REYNARD: Preparing each page only once avoids a trap storm on hot JIT paths
+// while still bootstrapping executable permissions for newly-touched pages.
+static bool ShouldRequestDebuggerPrepare(void* aAddress, size_t aSize) {
+  if (!aAddress || !aSize || !sExecutableMemoryBase) {
+    return true;
+  }
+
+  auto* executable = static_cast<uint8_t*>(aAddress);
+  auto* begin = sExecutableMemoryBase;
+  auto* end = begin + MaxCodeBytesPerProcess;
+  if (executable < begin || executable + aSize > end) {
+    return true;
+  }
+
+  uintptr_t rangeStart = reinterpret_cast<uintptr_t>(executable);
+  if (aSize > (std::numeric_limits<uintptr_t>::max() - rangeStart)) {
+    return true;
+  }
+
+  uintptr_t firstPageStart = rangeStart & ~(DebugPreparePageSize - 1);
+  uintptr_t lastPageStart =
+      (rangeStart + aSize - 1) & ~(DebugPreparePageSize - 1);
+
+  bool needsPrepare = false;
+  for (uintptr_t page = firstPageStart; page <= lastPageStart;
+       page += DebugPreparePageSize) {
+    if (ShouldRequestDebuggerPreparePage(page)) {
+      needsPrepare = true;
+    }
+  }
+
+  return needsPrepare;
+}
+
+// REYNARD: Ask the debugger-backed iOS JIT path to prepare a freshly
+// committed executable range so child processes can execute it.
+#  if defined(__aarch64__)
+__attribute__((noinline, optnone, naked)) static void
+DebuggerPrepareExecutableRegionTrap(void* aExecutableAddress,
+                                    void* aWritableAddress, size_t aSize) {
+  asm volatile(
+      "brk #0x69\n"
+      "ret\n");
+}
+
+static void RequestDebuggerPrepareExecutableRegion(void* aExecutableAddress,
+                                                   void* aWritableAddress,
+                                                   size_t aSize) {
+  DebuggerPrepareExecutableRegionTrap(aExecutableAddress, aWritableAddress,
+                                      aSize);
+}
+#  else
+static void RequestDebuggerPrepareExecutableRegion(void* aExecutableAddress,
+                                                   void* aWritableAddress,
+                                                   size_t aSize) {
+  (void)aExecutableAddress;
+  (void)aWritableAddress;
+  (void)aSize;
+}
+#  endif
+
+static void PrepareExecutableRegionForExecution(void* aAddress, size_t aSize) {
+  if (!aAddress || !aSize) {
+    return;
+  }
+
+  // REYNARD: Keep RX pages in sync by explicitly sourcing bytes from the
+  // writable alias before preparing instruction fetch on the executable view.
+  if (ShouldRequestDebuggerPrepare(aAddress, aSize)) {
+    void* writableAddress = WritableAliasForExecutableAddress(aAddress, aSize);
+    RequestDebuggerPrepareExecutableRegion(aAddress, writableAddress, aSize);
+  }
+  sys_cache_control(kCacheFunctionPrepareForExecution, aAddress, aSize);
+}
+
+// REYNARD: Keep executable and writable aliases in an explicit, stable
+// permission state so iOS does not leave JIT pages non-executable after a
+// write phase.
+static bool SetAliasProtection(void* executableAddress, void* writableAddress,
+                               size_t bytes, ProtectionSetting protection) {
+  int result = 0;
+  switch (protection) {
+    case ProtectionSetting::Writable:
+      result = mprotect(writableAddress, bytes, PROT_READ | PROT_WRITE);
+      if (result != 0) {
+#  ifdef XP_IOS
+        fprintf(stderr,
+                "REYNARD_DEBUG: SetAliasProtection writable mprotect failed, "
+                "pid=%d, writable=%p, bytes=%zu, errno=%d\n",
+                getpid(), writableAddress, bytes, errno);
+        fflush(stderr);
+#  endif
+        return false;
+      }
+
+      // REYNARD: Writable transitions mean code bytes can change; force the
+      // next executable transition to re-run debugger-backed page prepare.
+      InvalidateDebuggerPrepareCacheRange(executableAddress, bytes);
+
+      // REYNARD: On jailed iOS, removing EXEC from the executable alias and
+      // then restoring it can fail for child-process JIT pages. Keep the
+      // executable alias RX while writes go through the writable alias.
+      result = mprotect(executableAddress, bytes, PROT_READ | PROT_EXEC);
+      break;
+    case ProtectionSetting::Executable:
+      result = mprotect(writableAddress, bytes, PROT_READ);
+      if (result != 0) {
+#  ifdef XP_IOS
+        fprintf(stderr,
+                "REYNARD_DEBUG: SetAliasProtection executable writable-alias "
+                "mprotect failed, pid=%d, writable=%p, bytes=%zu, errno=%d\n",
+                getpid(), writableAddress, bytes, errno);
+        fflush(stderr);
+#  endif
+        return false;
+      }
+      result = mprotect(executableAddress, bytes, PROT_READ | PROT_EXEC);
+      break;
+  }
+
+#  ifdef XP_IOS
+  if (result != 0) {
+    fprintf(
+        stderr,
+        "REYNARD_DEBUG: SetAliasProtection executable-alias mprotect failed, "
+        "pid=%d, executable=%p, bytes=%zu, protection=%u, errno=%d\n",
+        getpid(), executableAddress, bytes, unsigned(protection), errno);
+    fflush(stderr);
+  }
+#  endif
+
+  return result == 0;
+}
+
+static void* WritableAliasForExecutableAddress(void* addr, size_t bytes) {
+  if (!sWritableExecutableMemoryBase || !sExecutableMemoryBase) {
+    return addr;
+  }
+
+  auto* executable = static_cast<uint8_t*>(addr);
+  MOZ_RELEASE_ASSERT(executable >= sExecutableMemoryBase &&
+                     executable + bytes <=
+                         sExecutableMemoryBase + MaxCodeBytesPerProcess);
+  return sWritableExecutableMemoryBase + (executable - sExecutableMemoryBase);
+}
